<% layout("/layouts/boilerplate") %>
    <div id="filters">
      <% categories.forEach(category=>{ %>
        <a href="/listings?category=<%= category._id %>" 
          class="filter <%= String(category._id) === String(categorySelected) ? 'active' : '' %><%#= categorySelected == category._id ? 'active' : '' %>">

<div>
<i class="fa-solid <%= category.icon %>"></i>
</div>

<p>
<%= category.name %>
</p>

</a>

<% }) %>
        <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
          <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
        </div>
        </div>
      
    </div>
    <% if(currUser && recentlyViewed.length > 0){ %>

<section class="continue-section">

<div class="continue-heading">

<h2>
Where your journey paused...
</h2>

<p>
Your last escapes are waiting for you.
</p>

</div>

<div class="row">

<% recentlyViewed.forEach(listing=>{ %>

<div class="col-lg-4">

<a
href="/listings/<%= listing._id %>"
class="listing-link"
>
<div class="card listing-card h-100">

<img
src="<%= listing.images[0]?.url %>"
class="card-img-top"
>

<div class="card-body">

<h5>
<%= listing.title %>
</h5>

<p class="text-muted">

<%= listing.location %>

</p>
<div class="continue-viewed-row">
  <i class="fa-regular fa-clock"></i>
  <span>Viewed recently</span>
  <b>₹<%= listing.price.toLocaleString("en-IN") %>/night</b>
</div>
<a href="/listings/<%= listing._id %>" class="continue-link">
  Continue <i class="fa-solid fa-arrow-right-long"></i>
</a>

</div>
</div>

</a>

</div>

<% }) %>

</div>

</section>

<% } %>
    <div id="listing-container" class="row row-cols-lg-3 row-cols-med-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){%>
        <a href="/listings/<%=listing._id%>" class="listing-link">
          <div class="card col listing-card" >
          <img 
src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : '/images/fallback.jpg' %>"
class="card-img-top" 
alt="listingimage" 
referrerpolicy="no-referrer"
style="height:20rem;">
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
              <b><%=listing.title%></b><br>
              &#8377;<%= listing.price.toLocaleString("en-IN")%>/night
              <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
              </p>
            </div>
          </div>
        </a>
    
    <%}%>


    </div>
    <% if(allListings.length === 0){ %>
    <div class="alert alert-info text-center empty-state">
           <i class="fa-solid fa-magnifying-glass"></i>
           <h4>No stays found</h4>
           <p>Try another category or explore all listings.</p>
           <a href="/listings" class="btn btn-dark mt-2">Explore All</a>
    </div>
<% } %>
    <% if(allListings.length > 0){ %>
     <div id="loader" class="text-center my-4">
    Loading more listings...
     </div>
    <% } %> 
      <script src="/js/pagination.js"></script>
    <script>
      let taxSwitch = document.getElementById("switchCheckDefault");
      taxSwitch.addEventListener("click",()=>{
        let taxInfo =document.getElementsByClassName("tax-info");
        for(info of taxInfo){
          if(info.style.display!="inline"){
             info.style.display ="inline";
          }else{
            info.style.display ="none";
          }
        }
      })
    </script>
    
   







