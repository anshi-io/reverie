<% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
    <div class="col-8 offset-2">
      
    <h3><b>CREATE A NEW LISTING</b></h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" placeholder="Enter title" type="text" class="form-control" required>
            <div class="invalid-feedback">Enter Title</div>
            <div class="valid-feedback">Looks Good</div>
        </div>
     
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" type="text" placeholder="Description of the stay location" class="form-control" required></textarea>
            <div class="invalid-feedback">Please enter short description about your title</div>
        </div>
        
        <div class="mb-3">
            <label for="image" class="form-label">Upload Image</label>
            <input name="listing[images]"  type="file" class="form-control" accept=".jpg,.jpeg,.png" multiple required>
            <div class="invalid-feedback">Invalid image format. Only JPG, JPEG, and PNG files are supported.</div>
        </div>

        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-label ">Price</label>
            <input name="listing[price]" placeholder="Enter Price"  class="form-control" required>
            <div class="invalid-feedback">Enter valid Price</div>
        </div>
        
        <div class="mb-3 col-md-8">
            <label for="image" class="form-label ">Location</label>
            <input name="listing[location]" placeholder="Enter Location" type="text" class="form-control" required>
            <div class="invalid-feedback">Enter valid location</div>
        </div>
        
        </div>
        
        
        <div class="mb-3"> 
            <label for="image" class="form-label">Country</label>
            <input name="listing[country]" placeholder="Enter Country" type="text" class="form-control" required >
            <div class="invalid-feedback">Enter valid country</div>
        </div>
        <br>
    <select
        name="listing[category]"
        class="form-select"
        required
    >
     <option value="" selected disabled hidden>Select Category</option>
     <% categories.forEach(category=>{ %>

     <option value="<%= category._id %>">
        <%= category.name %>
    </option>
    <% }) %>
    </select>

    <div class="invalid-feedback">
        Please select a category.
    </div>
    
        <button class="btn btn-dark add-btn mt-3">Add</button>
        
      
    </form>
    </div>
    </div>
</body>
