<script>
    const mapToken = "<%=process.env.MAP_TOKEN%>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
<main>
    <div class="show-container mt-4">
    <div class="show-header">
    <h1 class="listing-title"><%= listing.title %></h1>
    <p class="listing-location">
        <%= listing.location %>, <%= listing.country %>
    </p>
    </div>
    
   
<div class="listing-gallery">

<%
let imgs = listing.images || [];

if(imgs.length === 0 && listing.image){
    imgs = [listing.image];
}
%>


<div id="listingCarousel" class="carousel slide">

<div class="carousel-inner">


<% imgs.forEach((img,index)=>{ %>


<div class="carousel-item <%= index === 0 ? "active" : "" %>">


<img 
src="<%= img.url %>"
class="show-img"
alt="listing_image">


</div>


<% }) %>


</div>


<button 
class="carousel-control-prev"
data-bs-target="#listingCarousel"
data-bs-slide="prev">

<span class="carousel-control-prev-icon"></span>

</button>



<button 
class="carousel-control-next"
data-bs-target="#listingCarousel"
data-bs-slide="next">

<span class="carousel-control-next-icon"></span>

</button>


</div>


</div>


<%# ── after .listing-gallery closes ── %>

<div class="show-layout">

  <%# ── LEFT COLUMN ── %>
  <div class="show-content">

    <p class="host">
      Curated by <span>@<%= listing.owner.username %></span>
    </p>

    <p class="description"><%= listing.description %></p>

    <p class="price">₹<%= listing.price.toLocaleString("en-IN") %></p>

    <div class="meta">
      <span><i class="fa-solid fa-location-dot"></i> <%= listing.location %></span>
      <span><i class="fa-solid fa-globe"></i> <%= listing.country %></span>
    </div>

    <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
    <div class="action-bar">
      <a href="/listings/<%= listing._id %>/edit" class="btn-primary-action">EDIT</a>
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn-danger-action">DELETE</button>
      </form>
    </div>
    <% } %>

  </div><%# ── end left col ── %>
  <% if(currUser){ %>


<% if(isWishlisted){ %>


<form

action="/wishlist/<%= listing._id %>?_method=DELETE"

method="POST"

>


<button 
class="btn-wishlist wishlisted mb-3"
>

<i class="fa-solid fa-heart"></i>

Remove from Wishlist

</button>


</form>


<% }else{ %>



<form

action="/wishlist/<%= listing._id %>"

method="POST"

>


<button

class="btn-wishlist mb-3"

>

<i class="fa-regular fa-heart"></i>

</button>


</form>


<% } %>


<% } %>
  <%# ── RIGHT COLUMN ── %>
  <div class="trip-card">

<h5>
<i class="fa-solid fa-calendar-days"></i>
Stay Planner
</h5>


<form 
action="/bookings/check/<%= listing._id %>"
method="POST"
>


<div class="mb-3">

<label class="form-label">
Check In
</label>

<input 
type="date"
name="checkIn"
id="checkIn"
class="form-control"
required
>

</div>




<div class="mb-3">

<label class="form-label">
Check Out
</label>

<input 
type="date"
name="checkOut"
id="checkOut"
class="form-control"
required
>

</div>




<div class="mb-3">

<label class="form-label">
Guests
</label>


<input 
type="number"
name="guests"
class="form-control"
value="1"
min="1"
required
>


</div>



<div class="cost-row">

<span>
Price
</span>


<strong>

₹<%= listing.price.toLocaleString("en-IN") %>
/ night

</strong>

</div>


<hr>


<button 
class="btn-primary-action w-100"
type="submit"
>

Reserve

</button>


</form>


</div>

</div><%# ── end .show-layout ── %>



</div>

    
    <!-- <div class="col-8 offset-3 mb-3 mt-1"> -->
        <div class="reviews-section">
        <hr>
        <% if(currUser){%>
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews"  
            method="POST"
            novalidate
            class="needs-validation"
            >
            <!-- <div class="rate mb-3 mt-3">
                <label for="rating form-label">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div> -->
            <div class="rate mb-3 mt-3">
            <label for="rating form-label">Rating</label>
            <fieldset class="starability-growRotate">
            
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            </div>
            <div class="mb-3">
                <label for="comment form-label ">Comments</label>
                <textarea name="review[comment]" id="comment" colss="30" rows="4" class="form-control" required></textarea>
                <div class="invalid-feedback">
                Please add some comments for review
               </div>
            </div>
            
        
            <button class="btn btn-outline-dark mb-3">Submit</button>


        </form>
        <%}%>
     <div class="reviews-section">
     <% if(listing.reviews.length>0) { %>   
        <p><b><h5>REVIEWS</h5></b></p>
        </div>
        <div class="row">
        

    <% for(let review of listing.reviews){ %>

        <div class="col-8 mb-3">
          <%- include("../includes/replyCard.ejs",
            {
                review,
                listing,
                currUser
            }) %>

        </div><% } %>

        
</div>
<%}%>
</div>
<!-- <div class="col-6 offset-3 mb-3 mt-1"> -->
    <div class="map-section">
            <h3>WHERE YOU'LL BE</h3>
            <div id="map"></div>
</div>

<% if(similarListings.length > 0){ %>

<div class="similar-section mt-5">

<h3 class="mb-4">
You may also like
</h3>

<div class="row">

<% similarListings.forEach(listing=>{ %>

<div class="col-lg-4 col-md-6 mb-4">

<a
href="/listings/<%= listing._id %>"
class="listing-link"
>

<div class="card listing-card h-100">

<img
src="<%= listing.images[0]?.url || '/images/fallback.jpg' %>"
class="card-img-top"
alt="listing image"
>

<div class="card-body">

<b><%= listing.title %></b>

<p class="mb-0">

₹<%= listing.price.toLocaleString("en-IN") %>/night

</p>

</div>

</div>

</a>

</div>

<% }) %>

</div>

</div>

<% } %>

</div>
</main>
<script>

const today =
new Date()
.toISOString()
.split("T")[0];


document.getElementById("checkIn").min=today;

document.getElementById("checkOut").min=today;



document.getElementById("checkIn")
.addEventListener("change",function(){

document.getElementById("checkOut").min=this.value;


});


</script>
<script src="/js/map.js"></script>
    
   

