<% layout("/layouts/boilerplate") %>


<div class="container mt-5">


<h2>
Confirm your stay
</h2>


<div class="card p-4 mt-4">


<h4>
<%= listing.title %>
</h4>


<p>
<%= listing.location %>,
<%= listing.country %>
</p>


<hr>


<form 
action="/bookings/<%= listing._id %>"
method="POST"
>


<input 
type="hidden"
name="checkIn"
value="<%= checkIn %>"
>


<input 
type="hidden"
name="checkOut"
value="<%= checkOut %>"
>


<input 
type="hidden"
name="guests"
value="<%= guests %>"
>



<button 
class="btn-primary-action"
>

Confirm Booking

</button>


</form>


</div>


</div>