<% layout("/layouts/boilerplate") %>

<h2 class="trips-heading">Your Trips ✈️</h2>

<% if(bookings.length === 0){ %>
  <div class="alert alert-info">You don't have any bookings yet.</div>
<% } %>

<div class="booking-grid">
  <% bookings.forEach(booking => { %>
  <div class="booking-card">
    <img src="<%= booking.listing.images[0].url %>" alt="<%= booking.listing.title %>">
    <div class="booking-card-body">
      <h4><%= booking.listing.title %></h4>
      <p class="booking-location">
        <i class="fa-solid fa-location-dot"></i>
        <%= booking.listing.location %>, <%= booking.listing.country %>
      </p>
      <hr class="booking-divider">
      <div class="booking-meta">
        <p><b>Check In:</b> <%= booking.checkIn.toDateString() %></p>
        <p><b>Check Out:</b> <%= booking.checkOut.toDateString() %></p>
        <p><b>Guests:</b> <%= booking.guests %></p>
      </div>
      <p class="booking-total">Total: <span>₹<%= booking.totalPrice.toLocaleString("en-IN") %></span></p>
      <span class="booking-badge <%= booking.status %>"><%= booking.status %></span>
      <% if(
(booking.status==="modify-requested" || 
 booking.status==="cancel-requested")
&& 
booking.hostResponse==="pending"
){ %>

<div class="alert alert-warning mt-2">

Your request is waiting for host approval.

</div>

<% } %>



<% if(booking.hostResponse==="approved"){ %>

<div class="alert alert-success mt-2">

Your request has been approved by the host.

</div>

<% } %>



<% if(booking.hostResponse==="rejected"){ %>

<div class="alert alert-danger mt-2">

Your request has been rejected by the host.

Your original booking is still active.

</div>

<% } %>
      <% if(booking.status==="confirmed"){ %>


<form method="POST"
action="/bookings/<%=booking._id%>/cancel">

<button class="btn-cancel-request" type="submit">
  <i class="fa-solid fa-xmark"></i> Request Cancellation
</button>

</form>



<div class="modify-form">
  <p class="modify-form-title">Request Modification</p>
  <form method="POST" action="/bookings/<%=booking._id%>/modify">
    <div class="modify-dates">
      <input type="date" name="checkIn"
        min="<%= new Date().toISOString().split('T')[0] %>" required>
      <input type="date" name="checkOut"
        min="<%= new Date().toISOString().split('T')[0] %>" required>
    </div>
    <input type="number" name="guests" value="<%=booking.guests%>">
    <input type="text" name="reason" required
      placeholder="Tell host why you need modification">
    <button class="btn-modify-submit" type="submit">
      Request Modification
    </button>
  </form>
</div>



<% } %>
    </div>
  </div>
  <% }) %>
</div>