<nav class="navbar navbar-expand-md sticky-top">
  <div class="container-fluid navbar-inner">

    <!-- Brand — always visible -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-house-flag"></i> Reverie
    </a>

    <!-- Search bar — OUTSIDE collapse, always visible -->
    <form class="search-bar ms-auto me-2" role="search" action="/listings" method="GET">
      <input class="search-input" type="search" name="search"
        placeholder="Search destination"
        value="<%= typeof search !== 'undefined' ? search : '' %>">
      <div class="divider"></div>
      <button class="btn-search" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span class="search-label">Search</span>
      </button>
    </form>

    <!-- Hamburger — always visible -->
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Collapse — ONLY nav links -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings">Explore</a>
        <% if(currUser){ %>
         <a class="nav-link" href="/wishlist">
         <i class="fa-solid fa-heart"></i>
         Wishlist
        </a>
        <a class="nav-link" href="/bookings">
<i class="fa-solid fa-suitcase"></i>
Trips
</a>

        <% } %>
        <% if(currUser && isHost){ %>


<li class="nav-item">

<a class="nav-link"
href="/host/dashboard">

Requests

</a>


</li>


<% } %>
<% if (isSuperAdmin) { %>

<li class="nav-item">
    <a class="nav-link" href="/admin/categories">
        <i class="fa-solid fa-layer-group"></i>
        Platform Manager
    </a>
</li>

<% } %>

        <a class="nav-link" href="/listings/new">Host a Reverie</a>
        <% if(!currUser) { %>
          <a class="nav-link" href="/signup"><b>Sign Up</b></a>
          <a class="nav-link" href="/login"><b>Login</b></a>
        <% } %>
        <% if(currUser) { %>
          <a class="nav-link" href="/logout"><b>Log Out</b></a>
        <% } %>
      </div>
    </div>

  </div>
</nav>
<!-- Mobile search row — add this AFTER </nav> -->
<div class="mobile-search-row">
  <form class="search-bar-mobile" role="search" action="/listings" method="GET">
    <i class="fa-solid fa-magnifying-glass search-icon"></i>
    <input class="search-input" type="search" name="search"
      placeholder="Search destination"
      value="<%= typeof search !== 'undefined' ? search : '' %>">
    <button class="btn-search-mobile" type="submit">
      <i class="fa-solid fa-arrow-right"></i>
    </button>
  </form>
</div>