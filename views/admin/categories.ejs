<% layout("/layouts/boilerplate") %>

<div class="container py-5">

<h1>

Platform Categories

</h1>

<div class="row mt-4">

<% categories.forEach(category=>{ %>

<div class="col-md-4 mb-4">

<div class="card shadow-sm">

<div class="card-body">

<h4>

<%= category.name %>

</h4>

<a
href="/admin/categories/<%= category._id %>"
class="btn btn-outline-dark mt-3"
>

Manage Listings

</a>


</div>

</div>

</div>

<% }) %>

</div>

</div>